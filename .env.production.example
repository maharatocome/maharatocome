# ============================================================
# MAHARAtoCOME — Variables d'environnement PRODUCTION
# ============================================================
# Copiez ce fichier sur le serveur sous le nom ".env"
# et remplissez les valeurs réelles.
# NE JAMAIS COMMITTER ce fichier avec de vraies valeurs !
# ============================================================

# Base de données PostgreSQL
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://maharauser:VOTRE_MOT_DE_PASSE@localhost:5432/maharatocome"

# NextAuth — clé secrète (générez une clé aléatoire longue)
# Commande pour générer : openssl rand -base64 32
NEXTAUTH_SECRET="GENEREZ-UNE-CLE-ALEATOIRE-ICI"

# URL publique de votre application (avec https://)
NEXTAUTH_URL="https://votre-domaine.com"

# Environnement
NODE_ENV="production"
